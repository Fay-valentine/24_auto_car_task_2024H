# ==============================
# 白名单策略：只保留指定文件
# ==============================

# 先忽略所有文件
*

# ==============================
# 保留根目录的文件
# ==============================
!main.c
!ti_msp_dl_config.h
!ti_msp_dl_config.c
!empty.syscfg
!README.md
!README.html
!.gitignore

# ==============================
# 重新允许 keil 文件夹
# ==============================
!keil/
keil/*
!keil/APP/
!keil/BSP/
!keil/Mode/

# ==============================
# 保留 APP 文件夹及其所有内容
# ==============================
!keil/APP/**

# ==============================
# 保留 BSP 文件夹及其所有内容
# ==============================
!keil/BSP/**

# ==============================
# 保留 Mode 文件夹及其所有内容
# ==============================
!keil/Mode/**
